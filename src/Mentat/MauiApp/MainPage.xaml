<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mentat.MainPage"
             Title="Mentat">

    <Grid RowDefinitions="*, Auto, Auto, 2*"
          Padding="24"
          RowSpacing="20">

        <Button
            x:Name="RecordBtn"
            Grid.Row="1"
            Text="Record"
            FontSize="22"
            FontFamily="OpenSansSemibold"
            TextColor="White"
            BackgroundColor="#D32F2F"
            WidthRequest="220"
            HeightRequest="220"
            CornerRadius="110"
            HorizontalOptions="Center"
            Clicked="OnRecordClicked" />

        <VerticalStackLayout
            Grid.Row="2"
            Spacing="10"
            HorizontalOptions="Center">

            <ActivityIndicator
                x:Name="BusyIndicator"
                IsRunning="False"
                IsVisible="False"
                HorizontalOptions="Center" />

            <Label
                x:Name="StatusLabel"
                Text=""
                FontSize="16"
                TextColor="Gray"
                HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="3">
            <Label
                x:Name="TranscriptLabel"
                Text=""
                FontSize="15"
                LineBreakMode="WordWrap" />
        </ScrollView>

    </Grid>

</ContentPage>
